cat > .gitignore <<'EOF'
# Snakemake
.snakemake/
results/
logs/
benchmarks/
*.done

# Conda
.conda/
envs/*/
!workflow/envs/

# Python
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
*.egg-info/

# Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Large data — never commit
*.fastq.gz
*.fasta
*.fa
*.bam
*.bai
*.mtx
*.h5
*.gff3
*.gtf

# But allow small example/test data if you ever add it
!tests/data/*.csv

# Local config overrides
config/local.yaml
EOF

# Loose run logs in repo root
/snakemake_*.log
/Rplots.pdf
/rank_check.pdf

# resources/ is large regenerable data (whitelists ~60M, BLAST proteomes ~200M).
# Ignore the whole tree, but keep the curated pollen marker FASTA (small, hand-built input).
resources/
!resources/pollen_qc/
!resources/pollen_qc/pollen_markers.faa
