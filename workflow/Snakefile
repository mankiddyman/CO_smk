        """

def marker_sample_for(sample_id):
    """Map an scRNA sample to the sample that holds its reference marker set.
    Currently: all scRNA samples of a species point at the species' marker-reference hap."""
    species = samples.loc[sample_id, "species"]
    ref_rows = samples[
        (samples["species"] == species) &
        (samples["is_marker_reference"] == "yes")
    ]
    if len(ref_rows) == 0:
        raise ValueError(f"No marker reference sample for species {species}")
    return ref_rows.index[0]


def get_chromosomes(sample_id):
    """Read chromosome names from the FASTA index. Returns empty list if .fai doesn't exist yet."""
    fasta = samples.loc[sample_id, "assembly_fasta"]
    fai = fasta + ".fai"
    if not os.path.exists(fai):
        return []
    with open(fai) as f:
        return [line.split("\t")[0] for line in f if line.strip()]


rule hifi_align:
    """Align HiFi reads to the assembly. Run once per sample."""
    input:
        fasta = lambda w: samples.loc[w.sample, "assembly_fasta"],
        hifi  = lambda w: samples.loc[w.sample, "hifi_reads"],
    output:
        bam = "results/markers/{sample}/hifi.bam",
        bai = "results/markers/{sample}/hifi.bam.bai",
    log: "logs/hifi_align/{sample}.log"
    threads: 16
    resources:
        mem_mb = 64000,
        runtime = 180,  # 3h — was 28min actual for hap1
    conda: "envs/markers.yaml"
    shell:
        """
        if [ ! -f {input.fasta}.fai ]; then
            samtools faidx {input.fasta} 2>> {log}
        fi
        minimap2 -t {threads} -ax map-hifi {input.fasta} {input.hifi} 2>> {log} | \
            samtools sort -@ 4 -o {output.bam} - 2>> {log}
        samtools index {output.bam} 2>> {log}
        """


rule hifi_variants_per_chrom:
    """Call variants on one chromosome/scaffold. Parallelizable across {chrom}."""
    input:
        fasta = lambda w: samples.loc[w.sample, "assembly_fasta"],
        fai   = lambda w: samples.loc[w.sample, "assembly_fasta"] + ".fai",
        bam   = "results/markers/{sample}/hifi.bam",
        bai   = "results/markers/{sample}/hifi.bam.bai",
    output:
        vcf = "results/markers/{sample}/by_chrom/{chrom}.vcf.gz",
        tbi = "results/markers/{sample}/by_chrom/{chrom}.vcf.gz.tbi",
    log: "logs/hifi_variants_per_chrom/{sample}.{chrom}.log"
    threads: 2
    resources:
        mem_mb = 8000,
        runtime = 600,  # 10h ceiling per chrom; largest was ~8h serial
    conda: "envs/markers.yaml"
    shell:
        """
        mkdir -p results/markers/{wildcards.sample}/by_chrom
        bcftools mpileup -f {input.fasta} -q 20 -Q 20 -a AD,DP \
            -r {wildcards.chrom} {input.bam} 2>> {log} | \
        bcftools call -m -v -Oz -o {output.vcf} 2>> {log}
        bcftools index -t {output.vcf} 2>> {log}
        """


rule hifi_variants_merge:
    """Concatenate per-chromosome VCFs into the final raw VCF."""
    input:
        vcfs = lambda w: expand(
            "results/markers/{sample}/by_chrom/{chrom}.vcf.gz",
            sample=w.sample,
            chrom=get_chromosomes(w.sample),
        ),
    output:
        vcf = "results/markers/{sample}/hifi_raw.vcf.gz",
        tbi = "results/markers/{sample}/hifi_raw.vcf.gz.tbi",
    log: "logs/hifi_variants_merge/{sample}.log"
    threads: 2
    resources:
        mem_mb = 4000,
        runtime = 30,
    conda: "envs/markers.yaml"
    shell:
        """
        bcftools concat -Oz -o {output.vcf} {input.vcfs} 2>> {log}
        bcftools index -t {output.vcf} 2>> {log}
        """


