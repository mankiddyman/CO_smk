rule filter_markers:
    """Filter raw HiFi VCF to high-confidence heterozygous SNPs."""
    input:
        vcf = "results/markers/{sample}/hifi_raw.vcf.gz",
    output:
        vcf = "results/markers/{sample}/markers.vcf.gz",
        tbi = "results/markers/{sample}/markers.vcf.gz.tbi",
        tsv = "results/markers/{sample}/markers.tsv",
        summary = "results/markers/{sample}/filter_summary.txt",
    log: "logs/filter_markers/{sample}.log"
    threads: 2
    resources:
        mem_mb = 8000,
        runtime = 60,
    conda: "envs/markers.yaml"
    params:
        min_dp = config["marker_filters"]["min_dp"],
        max_dp = config["marker_filters"]["max_dp"],
        min_qual = config["marker_filters"]["min_qual"],
        min_ratio = config["marker_filters"]["min_alt_ratio"],
        max_ratio = config["marker_filters"]["max_alt_ratio"],
    shell:
        r"""
        # Filter: biallelic SNPs, het, DP range, QUAL, allele ratio
        # bcftools expression: INFO and FORMAT fields accessed by name
        bcftools view \
            -m2 -M2 -v snps \
            -g het \
            -e 'QUAL < {params.min_qual} || FMT/DP < {params.min_dp} || FMT/DP > {params.max_dp} || (FMT/AD[0:1] / FMT/DP) < {params.min_ratio} || (FMT/AD[0:1] / FMT/DP) > {params.max_ratio}' \
            -Oz -o {output.vcf} {input.vcf} 2> {log}
        bcftools index -t {output.vcf} 2>> {log}

        # Export to simple TSV: chrom, pos, ref, alt
        bcftools query \
            -f '%CHROM\t%POS\t%REF\t%ALT\n' \
            {output.vcf} > {output.tsv} 2>> {log}

        # Summary
        n_raw=$(bcftools view -H {input.vcf} | wc -l)
        n_filtered=$(wc -l < {output.tsv})
        echo "Raw variants: $n_raw"        > {output.summary}
        echo "Markers after filter: $n_filtered" >> {output.summary}
        echo "Retention: $(echo "scale=4; $n_filtered / $n_raw" | bc)" >> {output.summary}
        echo "" >> {output.summary}
        echo "Per-chromosome marker counts:" >> {output.summary}
        cut -f1 {output.tsv} | sort | uniq -c >> {output.summary}
        echo "" >> {output.summary}
        echo "Filter params: min_dp={params.min_dp}, max_dp={params.max_dp}, min_qual={params.min_qual}, ratio=[{params.min_ratio},{params.max_ratio}]" >> {output.summary}
        """


rule cell_snp_counting:
    """Per-cell allele counts at marker positions using cellsnp-lite."""
    input:
        bam = "results/starsolo/{sample}/Aligned.sortedByCoord.out.bam",
        bai = "results/starsolo/{sample}/Aligned.sortedByCoord.out.bam.bai",
        barcodes = "results/cells/{sample}/barcodes_called.tsv",
        markers = lambda w: f"results/markers/{marker_sample_for(w.sample)}/markers.vcf.gz",
        markers_tbi = lambda w: f"results/markers/{marker_sample_for(w.sample)}/markers.vcf.gz.tbi",
    output:
        dp = "results/snps/{sample}/cellSNP.tag.DP.mtx",
        ad = "results/snps/{sample}/cellSNP.tag.AD.mtx",
        oth = "results/snps/{sample}/cellSNP.tag.OTH.mtx",
        snp_samples = "results/snps/{sample}/cellSNP.samples.tsv",
        sites = "results/snps/{sample}/cellSNP.base.vcf.gz",
    log: "logs/cell_snp_counting/{sample}.log"
    threads: 16
    resources:
        mem_mb = 32000,
        runtime = 480,  # 8h ceiling; subset test was 25 min for 10% of markers
    conda: "envs/cellsnp.yaml"
    params:
        out_dir = lambda w: f"results/snps/{w.sample}",
    shell:
        """
        mkdir -p {params.out_dir}
        cellsnp-lite \
            -s {input.bam} \
            -b {input.barcodes} \
            -R {input.markers} \
            -O {params.out_dir} \
            -p {threads} \
            --minMAPQ 20 \
            --minLEN 30 \
            --minCOUNT 1 \
            --minMAF 0 \
            --cellTAG CB \
            --UMItag UB \
            --gzip \
            > {log} 2>&1
        """




rule cellsnp_to_per_cell:
    """Convert cellsnp-lite sparse matrices to per-cell TSVs in Meng's input format."""
    input:
        dp = "results/snps/{sample}/cellSNP.tag.DP.mtx",
        ad = "results/snps/{sample}/cellSNP.tag.AD.mtx",
        snp_samples = "results/snps/{sample}/cellSNP.samples.tsv",
        sites = "results/snps/{sample}/cellSNP.base.vcf.gz",
        fai = lambda w: samples.loc[w.sample, "assembly_fasta"] + ".fai",
    output:
        chrom_map = "results/cell_data/{sample}/chrom_map.tsv",
        summary = "results/cell_data/{sample}/conversion_summary.txt",
    log: "logs/cellsnp_to_per_cell/{sample}.log"
    threads: 1
    resources:
        mem_mb = 16000,
        runtime = 30,
    conda: "envs/cellsnp.yaml"
    params:
        cellsnp_dir = lambda w: f"results/snps/{w.sample}",
        out_dir = lambda w: f"results/cell_data/{w.sample}",
        min_markers = 50,
    shell:
        """
        python workflow/scripts/cellsnp_to_per_cell.py \
            --cellsnp_dir {params.cellsnp_dir} \
            --fai {input.fai} \
            --out_dir {params.out_dir} \
            --min_markers {params.min_markers} \
            > {log} 2>&1
        """



