rule select_cells:
    """Apply cell QC thresholds to identify cells suitable for CO calling."""
    input:
        switches = "results/cell_qc/{sample}/switches.tsv",
    output:
        good_cells = "results/cell_qc/{sample}/good_cells.tsv",
        summary = "results/cell_qc/{sample}/selection_summary.txt",
    log: "logs/select_cells/{sample}.log"
    threads: 1
    resources:
        mem_mb = 4000,
        runtime = 10,
    conda: "envs/cell_qc.yaml"
    params:
        min_total = config["cell_qc"]["min_total_markers"],
        min_per_chrom = config["cell_qc"]["min_per_chrom_markers"],
        max_sr = config["cell_qc"]["max_switch_rate"],
    shell:
        """
        Rscript workflow/scripts/select_cells.R \
            --switches {input.switches} \
            --out {output.good_cells} \
            --out_summary {output.summary} \
            --min_total_markers {params.min_total} \
            --min_per_chrom_markers {params.min_per_chrom} \
            --max_switch_rate {params.max_sr} \
            > {log} 2>&1
        """
