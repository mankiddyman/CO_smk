# workflow/Snakefile
import pandas as pd
import os
configfile: "config/config.yaml"

samples = pd.read_csv("config/samples.csv").set_index("sample_id", drop=False)
SAMPLES = samples.index.tolist()
marker_samples = samples[samples["is_marker_reference"] == "yes"].index.tolist()
# ...


rule all:
    input:
        expand("results/starsolo/{sample}/Solo.out/GeneFull/raw/matrix.mtx", sample=SAMPLES),
        expand("results/cells/{sample}/qc_summary.tsv", sample=SAMPLES),
        expand("results/markers/{sample}/markers.tsv", sample=marker_samples),
        expand("results/cells/{sample}/knee_plot.pdf",sample=SAMPLES),
        expand("results/markers/{sample}/diagnostic_histograms.pdf", sample=marker_samples),
        expand("results/snps/{sample}/cellSNP.tag.DP.mtx", sample=SAMPLES),
        expand("results/cell_qc/{sample}/good_cells.tsv", sample=SAMPLES),
        expand("results/cell_qc/{sample}/switch_diagnostics.pdf", sample=SAMPLES),
rule gff_to_gtf:
    input:
        gff = lambda w: samples.loc[w.sample, "annotation_gff"],
    output:
        gtf = "results/annotation/{sample}.gtf",
    log: "logs/gff_to_gtf/{sample}.log"
    threads: 1
    resources: mem_mb=4000, runtime=30
    conda: "envs/star.yaml"
    shell:
        r"""
        mkdir -p results/annotation
        gffread {input.gff} -T 2> {log} | \
        awk 'BEGIN{{FS=OFS="\t"}} /^#/ {{print; next}} {{
            match($9, /gene_id "[^"]+";?/); gid = substr($9, RSTART, RLENGTH)
            match($9, /transcript_id "[^"]+";?/); tid = substr($9, RSTART, RLENGTH)
            if (gid !~ /;$/) gid = gid ";"
            if (tid !~ /;$/) tid = tid ";"
            $9 = gid " " tid
            print
        }}' > {output.gtf}
        """


rule star_index:
    input:
        fasta = lambda w: samples.loc[w.sample, "assembly_fasta"],
        gtf   = "results/annotation/{sample}.gtf",
    output:
        directory("results/star_index/{sample}"),
        done = "results/star_index/{sample}/.done",
    log: "logs/star_index/{sample}.log"
    benchmark: "benchmarks/star_index/{sample}.tsv"
    threads: 16
    resources: mem_mb=64000, runtime=240
    conda: "envs/star.yaml"
    shell:
        """
        mkdir -p {output[0]}
        STAR --runMode genomeGenerate \
             --runThreadN {threads} \
             --genomeDir {output[0]} \
             --genomeFastaFiles {input.fasta} \
             --sjdbGTFfile {input.gtf} \
             --sjdbOverhang 99 \
             --genomeSAindexNbases 13 \
             > {log} 2>&1
        touch {output.done}
        """

rule starsolo_align:
    input:
        index = "results/star_index/{sample}/.done",
        r1    = lambda w: samples.loc[w.sample, "scrna_r1"],
        r3    = lambda w: samples.loc[w.sample, "scrna_r3"],
        whitelist = config["whitelist_5p_v1"],
    output:
        matrix = "results/starsolo/{sample}/Solo.out/GeneFull/raw/matrix.mtx",
        bam    = "results/starsolo/{sample}/Aligned.sortedByCoord.out.bam",
        bai    = "results/starsolo/{sample}/Aligned.sortedByCoord.out.bam.bai",
        summary = "results/starsolo/{sample}/Solo.out/Gene/Summary.csv",
        done   = "results/starsolo/{sample}/.done",
    log: "logs/starsolo/{sample}.log"
    benchmark: "benchmarks/starsolo/{sample}.tsv"
    threads: 16
    resources:
        mem_mb = 80000,
        runtime = 480,
    conda: "envs/star.yaml"
    params:
        index_dir = lambda w: f"results/star_index/{w.sample}",
        out_prefix = lambda w: f"results/starsolo/{w.sample}/",
    shell:
        """
        mkdir -p {params.out_prefix}
        STAR --runMode alignReads \
             --runThreadN {threads} \
             --genomeDir {params.index_dir} \
             --readFilesIn {input.r3} {input.r1} \
             --readFilesCommand zcat \
             --soloType CB_UMI_Simple \
             --soloCBwhitelist {input.whitelist} \
             --soloCBstart 1 --soloCBlen 16 \
             --soloUMIstart 17 --soloUMIlen 10 \
             --soloFeatures Gene GeneFull \
             --soloStrand Reverse \
             --soloUMIfiltering MultiGeneUMI_CR \
             --soloUMIdedup 1MM_CR \
             --soloCBmatchWLtype 1MM_multi_Nbase_pseudocounts \
             --soloCellFilter None \
             --soloBarcodeReadLength 0 \
             --outSAMtype BAM SortedByCoordinate \
             --outSAMattributes NH HI nM AS CR UR CB UB GX GN sS sQ sM \
             --outFileNamePrefix {params.out_prefix} \
             > {log} 2>&1
        samtools index -@ 4 {output.bam} 2>> {log}
        touch {output.done}
        """


